                  "    console.log('Missions this week:', res.missions_completed);",
                  "    console.log('XP this week:', res.total_xp_earned);",
                  "    console.log('Avg score:', res.average_final_score);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/player/{{childId}}/stats/weekly", "host": ["{{baseUrl}}"], "path": ["api", "player", "{{childId}}", "stats", "weekly"] },
            "description": "Returns weekly performance — missions completed, XP earned, avg score, strongest/weakest attribute."
          }
        }
      ]
    },
    {
      "name": "👨‍👩‍👧 Parent",
      "item": [
        {
          "name": "Approve Child",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Child approved', () => pm.response.to.have.status(200));",
