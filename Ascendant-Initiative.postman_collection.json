          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{parentToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/parent/{{parentId}}/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "parent", "{{parentId}}", "dashboard"] },
            "description": "Returns all approved children with level, XP, streak, identity and weekly summary."
          }
        },
