                  "    pm.test('Mission created', () => pm.response.to.have.status(201));",
                  "    pm.test('Has ID', () => pm.expect(res.id).to.be.a('string'));",
                  "    console.log('New mission ID:', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"The School Election\",\n    \"narrative\": \"Two students are running for class monitor. You are the deciding vote. Who would you choose and why?\",\n    \"difficulty_level\": 3,\n    \"mission_type\": \"ANALYTICAL\",\n    \"rule_weight\": 0.3,\n    \"ai_weight\": 0.7,\n    \"scenario\": {\n        \"context\": \"Candidate A is very organized and responsible but quite strict. Candidate B is popular and friendly but sometimes forgetful. Both want to help the class. Who would you vote for and why? Think about what qualities make a good leader.\",\n        \"open_response\": true\n    }\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/missions", "host": ["{{baseUrl}}"], "path": ["api", "admin", "missions"] },
            "description": "Create a new mission. New mission ID auto-saved to newMissionId variable."
          }
