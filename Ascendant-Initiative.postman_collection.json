{
  "info": {
    "name": "Ascendant Initiative API",
    "description": "Complete API collection for the Ascendant Initiative backend — a gamified cognitive training platform for kids aged 9-12.\n\n## Setup\n1. Set the `baseUrl` variable to `http://localhost:8080`\n2. Register a parent, then a child\n3. Token variables auto-fill after login\n\n## Flow\nRegister → Login → List Missions → Submit Response → Poll Result → Check Profile → Parent Dashboard → Admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080", "type": "string" },
    { "key": "childToken",   "value": "", "type": "string" },
    { "key": "parentToken",  "value": "", "type": "string" },
    { "key": "adminToken",   "value": "", "type": "string" },
    { "key": "childId",      "value": "", "type": "string" },
    { "key": "parentId",     "value": "", "type": "string" },
    { "key": "missionId",    "value": "", "type": "string" },
    { "key": "scenarioId",   "value": "", "type": "string" },
    { "key": "responseId",   "value": "", "type": "string" },
    { "key": "newMissionId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register Parent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('parentToken', res.token);",
                  "    pm.collectionVariables.set('parentId', res.user.id);",
                  "    pm.test('Parent registered successfully', () => pm.response.to.have.status(201));",
                  "    pm.test('Token received', () => pm.expect(res.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Parent\",\n    \"email\": \"parent@test.com\",\n    \"password\": \"Test@1234\",\n    \"role\": \"PARENT\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "description": "Register a new parent account. Token is auto-saved to parentToken variable."
          }
        },
        {
          "name": "Register Child",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('childToken', res.token);",
                  "    pm.collectionVariables.set('childId', res.user.id);",
                  "    pm.test('Child registered successfully', () => pm.response.to.have.status(201));",
                  "    pm.test('Player profile created', () => pm.expect(res.user.id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Child\",\n    \"email\": \"child@test.com\",\n    \"password\": \"Test@1234\",\n    \"role\": \"CHILD\",\n    \"parentEmail\": \"parent@test.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "description": "Register a new child account linked to a parent. Token is auto-saved to childToken variable."
          }
        },
        {
          "name": "Login — Child",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('childToken', res.token);",
                  "    pm.collectionVariables.set('childId', res.user.id);",
                  "    pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "    pm.test('Fresh token received', () => pm.expect(res.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"child@test.com\",\n    \"password\": \"Test@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Login as child. Fresh token auto-saved to childToken."
          }
        },
        {
          "name": "Login — Parent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('parentToken', res.token);",
                  "    pm.collectionVariables.set('parentId', res.user.id);",
                  "    pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"parent@test.com\",\n    \"password\": \"Test@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Login as parent. Token auto-saved to parentToken."
          }
        },
        {
          "name": "Login — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('adminToken', res.token);",
                  "    pm.test('Admin login successful', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@ascendant.app\",\n    \"password\": \"Admin@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Login as admin. Token auto-saved to adminToken."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh_token\": \"<paste refresh token here>\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] },
            "description": "Get a new access token using a refresh token. Note: use 'refresh_token' (snake_case)."
          }
        }
      ]
    },
    {
      "name": "🎯 Missions",
      "item": [
        {
          "name": "List All Missions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.test('Returns mission list', () => pm.expect(res).to.be.an('array'));",
                  "    pm.test('Has at least one mission', () => pm.expect(res.length).to.be.above(0));",
                  "    if (res.length > 0) {",
                  "        pm.collectionVariables.set('missionId', res[0].id);",
                  "        console.log('Auto-set missionId to:', res[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/missions", "host": ["{{baseUrl}}"], "path": ["api", "missions"] },
            "description": "Returns all active missions. First mission ID is auto-saved to missionId variable."
          }
        },
        {
          "name": "Get Next Mission",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/missions/next", "host": ["{{baseUrl}}"], "path": ["api", "missions", "next"] },
            "description": "Returns the next incomplete mission for the authenticated child."
          }
        },
        {
          "name": "Get Mission Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('missionId', res.id);",
                  "    pm.collectionVariables.set('scenarioId', res.scenario.id);",
                  "    pm.test('Mission detail returned', () => pm.response.to.have.status(200));",
                  "    pm.test('Scenario present', () => pm.expect(res.scenario).to.be.an('object'));",
                  "    console.log('missionId:', res.id);",
                  "    console.log('scenarioId:', res.scenario.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/missions/{{missionId}}", "host": ["{{baseUrl}}"], "path": ["api", "missions", "{{missionId}}"] },
            "description": "Get full mission detail including scenario. missionId and scenarioId are auto-saved for Step 8."
          }
        },
        {
          "name": "Get Mission Detail — Lemonade Stand",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('missionId', res.id);",
                  "    pm.collectionVariables.set('scenarioId', res.scenario.id);",
                  "    console.log('missionId:', res.id, 'scenarioId:', res.scenario.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/missions/a1000000-0000-0000-0000-000000000001", "host": ["{{baseUrl}}"], "path": ["api", "missions", "a1000000-0000-0000-0000-000000000001"] },
            "description": "Get The Lemonade Stand mission directly by its seed ID."
          }
        },
        {
          "name": "Get Mission Detail — Broken Bridge",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('missionId', res.id);",
                  "    pm.collectionVariables.set('scenarioId', res.scenario.id);",
                  "    console.log('missionId:', res.id, 'scenarioId:', res.scenario.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/missions/a1000000-0000-0000-0000-000000000002", "host": ["{{baseUrl}}"], "path": ["api", "missions", "a1000000-0000-0000-0000-000000000002"] },
            "description": "Get The Broken Bridge mission directly by its seed ID."
          }
        },
        {
          "name": "Get Mission Detail — 404 Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 404 for unknown mission', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/missions/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api", "missions", "00000000-0000-0000-0000-000000000000"] },
            "description": "Should return 404 Not Found."
          }
        }
      ]
    },
    {
      "name": "📝 Responses & Evaluation",
      "item": [
        {
          "name": "Submit Response",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('responseId', res.responseId);",
                  "    pm.test('Response accepted', () => pm.response.to.have.status(202));",
                  "    pm.test('Status is PENDING', () => pm.expect(res.status).to.equal('PENDING'));",
                  "    pm.test('responseId received', () => pm.expect(res.responseId).to.be.a('string'));",
                  "    console.log('responseId auto-saved:', res.responseId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{childToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userId\": \"{{childId}}\",\n    \"missionId\": \"{{missionId}}\",\n    \"scenarioId\": \"{{scenarioId}}\",\n    \"answerText\": \"I think Person B is right because you should always check the whole bridge before fixing one part. If another section is also weak, fixing just the middle will not make it safe. Therefore the village should follow these steps. First, split the 20 adults into two groups. One group inspects the entire bridge while the other group gathers all the tools and planks. Second, if the rest of the bridge is safe, use the wooden planks to cover the 3 metre gap. Since each plank is 2 metres long, they need to overlap them so they reach across. Third, use the nails and hammer to fix the planks firmly so they do not slip. Then tie rope on both sides as a handrail so children can hold on while crossing.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/responses", "host": ["{{baseUrl}}"], "path": ["api", "responses"] },
            "description": "Submit an answer to a mission. Returns 202 immediately. responseId is auto-saved. Poll the evaluation endpoint until status = DONE."
          }
        },
        {
          "name": "Poll Evaluation Result",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Response OK', () => pm.response.to.have.status(200));",
                  "pm.test('Has status field', () => pm.expect(res.status).to.be.oneOf(['PENDING', 'DONE', 'FAILED']));",
                  "if (res.status === 'DONE') {",
                  "    pm.test('Has evaluation', () => pm.expect(res.evaluation).to.be.an('object'));",
                  "    pm.test('Has finalScore', () => pm.expect(res.evaluation.finalScore).to.be.a('number'));",
                  "    pm.test('AI was used', () => pm.expect(res.evaluation.aiTokensUsed).to.be.above(0));",
                  "    console.log('✅ DONE! finalScore:', res.evaluation.finalScore);",
                  "    console.log('ruleScore:', res.evaluation.ruleScore);",
                  "    console.log('aiScore:', res.evaluation.aiScore);",
                  "    console.log('feedback:', res.evaluation.feedbackText);",
                  "} else {",
                  "    console.log('⏳ Still PENDING... wait 3s and try again');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/responses/{{responseId}}/evaluation", "host": ["{{baseUrl}}"], "path": ["api", "responses", "{{responseId}}", "evaluation"] },
            "description": "Poll this every 3-5 seconds until status = DONE. responseId is auto-filled from Submit Response."
          }
        },
        {
          "name": "Submit Response — Too Short (400 Test)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400 for short answer', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{childToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userId\": \"{{childId}}\",\n    \"missionId\": \"{{missionId}}\",\n    \"scenarioId\": \"{{scenarioId}}\",\n    \"answerText\": \"Too short\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/responses", "host": ["{{baseUrl}}"], "path": ["api", "responses"] },
            "description": "Should return 400 Bad Request — answer is too short."
          }
        }
      ]
    },
    {
      "name": "👤 Player",
      "item": [
        {
          "name": "Get Player Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.test('Profile returned', () => pm.response.to.have.status(200));",
                  "    pm.test('Has XP', () => pm.expect(res.xp).to.be.a('number'));",
                  "    pm.test('Has level', () => pm.expect(res.level).to.be.a('number'));",
                  "    pm.test('Has identity', () => pm.expect(res.identity_type).to.be.a('string'));",
                  "    console.log('XP:', res.xp, '| Level:', res.level, '| Identity:', res.identity_type);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/player/{{childId}}/profile", "host": ["{{baseUrl}}"], "path": ["api", "player", "{{childId}}", "profile"] },
            "description": "Returns full player profile — XP, level, attributes, streak, identity type."
          }
        },
        {
          "name": "Get Progression History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Progression returned', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{childToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/player/{{childId}}/progression?limit=10", "host": ["{{baseUrl}}"], "path": ["api", "player", "{{childId}}", "progression"], "query": [{ "key": "limit", "value": "10" }] },
            "description": "Returns list of completed missions with XP earned and scores."
          }
        },
        {
          "name": "Get Weekly Stats",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
