    {
      "name": "🛡️ Admin",
      "item": [
        {
          "name": "List Users — All Children",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Users returned', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(res).to.be.an('array'));",
                  "console.log('Total children:', res.length);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users?role=CHILD&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users"], "query": [{ "key": "role", "value": "CHILD" }, { "key": "limit", "value": "10" }] },
            "description": "List all users filtered by role. Admin only."
